<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Export Compliance: identisch zur Haupt-App (nur Standard-
	     HTTPS), damit auch die Extension den Compliance-Dialog
	     nicht mehr triggert. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>NSExtension</key>
	<dict>
		<key>NSExtensionAttributes</key>
		<dict>
			<!--
			  Aktivierungsregeln fuer die Share-Extension.
			  Trennung nach Attachment-Typ — iOS entscheidet anhand der
			  UTType-Conformance des Items, welche Extension im Share-Sheet
			  auftaucht:
			    - Fotos-App teilt als "Image"  → Image-Keys
			    - Files-App / Safari-PDF teilt als "File" → File-Keys
			  "Strings" und "URLs" lassen wir bewusst weg — Drucken von Text
			  oder Links ist kein Mobile-Print-Usecase.
			-->
			<key>NSExtensionActivationRule</key>
			<dict>
				<key>NSExtensionActivationSupportsImageWithMaxCount</key>
				<integer>10</integer>
				<key>NSExtensionActivationSupportsFileWithMaxCount</key>
				<integer>10</integer>
			</dict>
		</dict>
		<key>NSExtensionMainStoryboard</key>
		<string>MainInterface</string>
		<key>NSExtensionPointIdentifier</key>
		<string>com.apple.share-services</string>
	</dict>
</dict>
</plist>
