    "Auswahl wird danach auf SecurePrint zurückgesetzt, damit du nicht versehentlich dauerhaft an ein Delegate druckst.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Afterwards the selection resets to SecurePrint so you don’t accidentally keep printing to a delegate."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Después, la selección vuelve a SecurePrint para que no sigas imprimiendo accidentalmente hacia un delegado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La sélection revient ensuite à SecurePrint pour éviter d’imprimer accidentellement vers un délégué de façon permanente."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Successivamente la selezione torna a SecurePrint così non stampi accidentalmente in modo permanente verso un delegato."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Valget tilbakestilles etterpå til SecurePrint, slik at du ikke ved et uhell fortsetter å skrive ut til en delegat."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Daarna wordt de selectie teruggezet op SecurePrint, zodat je niet per ongeluk permanent naar een delegate print."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Valet återställs efteråt till SecurePrint så att du inte av misstag fortsätter skriva ut till en delegat."
          }
        }
      }
    },
