<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>Mobile Print</string>
	<!-- Export Compliance: Wir nutzen ausschliesslich iOS-Standard-
	     Verschlüsselung (HTTPS via URLSession). Das befreit uns von
	     der jaehrlichen Export-Erklaerung nach US-Recht. Setzt den
	     Flag auf "false", damit App Store Connect bei jedem Upload
	     NICHT erneut "Fehlende Compliance" anzeigt. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<!-- App Transport Security: Die Server-URL ist vom User frei
	     konfigurierbar — viele betreiben den Printix-MCP-Server intern
	     ohne oeffentliches TLS-Zertifikat (LAN, Self-Hosted, dev).
	     Ohne diese Ausnahme scheitert jeder http://-Login an iOS-ATS.
	     App-Store-Review: als "self-configurable server" begruendbar. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
	<key>NSCameraUsageDescription</key>
	<string>Mobile Print nutzt die Kamera, um den QR-Code aus dem Mitarbeiter-Portal zu scannen und den Server automatisch einzurichten.</string>
	<key>NFCReaderUsageDescription</key>
	<string>Mobile Print liest die UID deiner RFID-Karte (z.B. Firmenausweis), damit du sie zum Druck-Release zuordnen kannst.</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>printixmobileprint</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>printixmobileprint</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
