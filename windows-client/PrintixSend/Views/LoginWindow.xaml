<Window x:Class="PrintixSend.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Printix Send — Anmelden" Height="480" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource BgBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Printix Send" FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
            <TextBlock x:Name="TxtServerHint" Text="Server: https://..." Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <Button x:Name="BtnEntra" Click="OnEntraLogin"
                    Style="{StaticResource PrimaryButton}" Height="44"
                    Background="#2563EB">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="🔐  Mit Microsoft anmelden" FontSize="14"/>
                </StackPanel>
            </Button>

            <Grid Margin="0,20,0,16">
                <Rectangle Height="1" Fill="{StaticResource BorderBrush}" VerticalAlignment="Center"/>
                <Border Background="{StaticResource BgBrush}" HorizontalAlignment="Center" Padding="8,0">
                    <TextBlock Text="oder lokal" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                </Border>
            </Grid>

            <TextBlock Text="Benutzername" Margin="0,0,0,4" Foreground="{StaticResource TextBrush}"/>
            <TextBox x:Name="TxtUsername"/>

            <TextBlock Text="Passwort" Margin="0,12,0,4" Foreground="{StaticResource TextBrush}"/>
            <PasswordBox x:Name="TxtPassword"/>

            <TextBlock x:Name="TxtError" Foreground="{StaticResource ErrorBrush}" Margin="0,12,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Einstellungen…" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="OnSettings"/>
            <Button Content="Anmelden" Style="{StaticResource PrimaryButton}" Click="OnLocalLogin" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
