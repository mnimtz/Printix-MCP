<Window x:Class="PrintixSend.Views.SendWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Printix Send" Height="560" Width="520"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize" MinHeight="480" MinWidth="480"
        Background="{StaticResource BgBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Printix Send" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                <TextBlock x:Name="TxtUserHint" Text="Angemeldet als …" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
            </StackPanel>
            <Button DockPanel.Dock="Right" Content="Abmelden" Style="{StaticResource SecondaryButton}"
                    Click="OnLogout" HorizontalAlignment="Right"/>
        </DockPanel>

        <!-- Files -->
        <Border Grid.Row="1" Background="{StaticResource CardBrush}" CornerRadius="8"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="12" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Dateien" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                <ListBox x:Name="LstFiles" MaxHeight="100" BorderThickness="0" Background="Transparent"/>
            </StackPanel>
        </Border>

        <!-- Target -->
        <TextBlock Grid.Row="2" Text="Ziel auswählen" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
        <ListBox Grid.Row="3" x:Name="LstTargets" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                 Background="{StaticResource CardBrush}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🖨️" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Text="{Binding Description}" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                        </StackPanel>
                        <Border Grid.Column="2" Background="{StaticResource AccentLightBrush}" CornerRadius="4"
                                Padding="6,2" VerticalAlignment="Center"
                                Visibility="{Binding IsDefault, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Standard" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Status -->
        <StackPanel Grid.Row="4" Margin="0,12,0,0">
            <TextBlock x:Name="TxtStatus" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
            <ProgressBar x:Name="ProgBar" Height="4" Margin="0,6,0,0" Visibility="Collapsed"/>
        </StackPanel>

        <!-- Actions -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Abbrechen" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="OnCancel"/>
            <Button x:Name="BtnSend" Content="Senden" Style="{StaticResource PrimaryButton}" Click="OnSend" IsDefault="True" MinWidth="100"/>
        </StackPanel>

    </Grid>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
</Window>
