<Window x:Class="PrintixSend.Views.HomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Printix Send" Height="520" Width="620"
        MinHeight="420" MinWidth="520"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        ResizeMode="CanResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Printix Send" FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
            <TextBlock x:Name="TxtUser" Text="…" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0"/>
            <TextBlock x:Name="TxtServer" Text="" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <Border Background="{StaticResource CardBrush}" CornerRadius="8"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="14" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="So sendest du Dateien" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" FontSize="12">
                        Rechtsklick auf eine Datei im Explorer → „Senden an" → wähle dein Ziel
                        (z. B. „Send2Printix — Mein Secure Print" oder einen Delegate-Eintrag).
                    </TextBlock>
                </StackPanel>
            </Border>

            <StackPanel x:Name="TargetsPanel"/>
        </StackPanel>

        <!-- v6.7.49: WrapPanel + Margin all around, damit Buttons bei schmalem
             Fenster in die nächste Zeile umbrechen statt abgeschnitten zu werden. -->
        <WrapPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button Content="Ziele aktualisieren" Style="{StaticResource SecondaryButton}" Margin="0,4,8,0" Click="OnRefresh"/>
            <Button Content="Server-Einstellungen" Style="{StaticResource SecondaryButton}" Margin="0,4,8,0" Click="OnConfig"/>
            <Button Content="Abmelden" Style="{StaticResource SecondaryButton}" Margin="0,4,8,0" Click="OnLogout"/>
            <Button Content="Schließen" Style="{StaticResource PrimaryButton}" Margin="0,4,0,0" Click="OnClose"/>
        </WrapPanel>
    </Grid>
</Window>
