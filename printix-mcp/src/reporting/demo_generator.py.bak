"""
Demo Data Generator — Printix BI Datenbank
==========================================
Generiert realistische Demo-Daten für eine eigene Azure SQL-Datenbank.

Features:
  - 3 Unternehmensgrößen-Presets: Kleinunternehmen / Mittelstand / Großunternehmen
  - Kulturell passende Namen in 11 Sprachen (DE, EN, FR, IT, ES, NL, SV, NO, PT, PL, JP-style)
  - Herstellerbasierte Drucker-Namenskonvention (HP, Xerox, Canon, Ricoh, KM, Kyocera u.a.)
  - Realistische Druckvolumen-Verteilung (Saisonalität, Tageszeiten, Duplex/Farbe)
  - Print-Queues pro Drucker (1-3 Queues, benannt nach Drucker+Typ)
  - Print-, Scan- und Kopieraufträge mit Dateinamen und Capture-Workflows
  - Abteilungsbasierte Volumengewichtung (FIN/PRD drucken mehr als HR/IT)
  - Komplettes Rollback via demo_session_id — alle Demo-Daten löschbar

Schema: Eigenes 'demo'-Schema (kein Konflikt mit Printix dbo-Tabellen).
Alle Tabellen liegen unter demo.* — Printix-Tabellen unter dbo.* bleiben unangetastet.
"""

import uuid
import json
import random
import logging
import math
from datetime import datetime, timedelta, timezone
from typing import Optional

logger = logging.getLogger(__name__)

