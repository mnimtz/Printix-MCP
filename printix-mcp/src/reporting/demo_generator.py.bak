# ── Azure SQL Schema (eigenes 'demo'-Schema) ───────────────────────────────────

SCHEMA_STATEMENTS: list[str] = [
    # 0) Schema anlegen (idempotent)
    """
    IF NOT EXISTS (SELECT 1 FROM sys.schemas WHERE name='demo')
    EXEC('CREATE SCHEMA demo')
    """,
    # 1) Networks
    """
    IF NOT EXISTS (SELECT 1 FROM sys.tables WHERE name='networks' AND schema_id=SCHEMA_ID('demo'))
    CREATE TABLE demo.networks (
        id              NVARCHAR(100) NOT NULL,
        tenant_id       NVARCHAR(100) NOT NULL,
        name            NVARCHAR(255) NOT NULL,
        demo_session_id NVARCHAR(100) NULL,
        CONSTRAINT PK_demo_networks PRIMARY KEY (id)
    )
    """,
    # 2) Users
    """
    IF NOT EXISTS (SELECT 1 FROM sys.tables WHERE name='users' AND schema_id=SCHEMA_ID('demo'))
    CREATE TABLE demo.users (
        id              NVARCHAR(100) NOT NULL,
        tenant_id       NVARCHAR(100) NOT NULL,
        email           NVARCHAR(255) NOT NULL,
        name            NVARCHAR(255) NOT NULL,
        department      NVARCHAR(255) NULL,
        demo_session_id NVARCHAR(100) NULL,
        CONSTRAINT PK_demo_users PRIMARY KEY (id)
    )
    """,
    # 3) Printers
    """
    IF NOT EXISTS (SELECT 1 FROM sys.tables WHERE name='printers' AND schema_id=SCHEMA_ID('demo'))
    CREATE TABLE demo.printers (
        id              NVARCHAR(100) NOT NULL,
        tenant_id       NVARCHAR(100) NOT NULL,
        name            NVARCHAR(255) NOT NULL,
        model_name      NVARCHAR(255) NULL,
        vendor_name     NVARCHAR(255) NULL,
        network_id      NVARCHAR(100) NULL,
        location        NVARCHAR(255) NULL,
        demo_session_id NVARCHAR(100) NULL,
        CONSTRAINT PK_demo_printers PRIMARY KEY (id)
    )
    """,
    # 4) Queues
    """
    IF NOT EXISTS (SELECT 1 FROM sys.tables WHERE name='queues' AND schema_id=SCHEMA_ID('demo'))
    CREATE TABLE demo.queues (
        id              NVARCHAR(100) NOT NULL,
        tenant_id       NVARCHAR(100) NOT NULL,
        name            NVARCHAR(255) NOT NULL,
        queue_type      NVARCHAR(100) NULL,
        printer_id      NVARCHAR(100) NULL,
        demo_session_id NVARCHAR(100) NULL,
        CONSTRAINT PK_demo_queues PRIMARY KEY (id)
    )
    """,
    # 5) Print Jobs
    """
    IF NOT EXISTS (SELECT 1 FROM sys.tables WHERE name='jobs' AND schema_id=SCHEMA_ID('demo'))
    CREATE TABLE demo.jobs (
        id              NVARCHAR(100) NOT NULL,
        tenant_id       NVARCHAR(100) NOT NULL,
        color           BIT          NOT NULL DEFAULT 0,
        duplex          BIT          NOT NULL DEFAULT 0,
        page_count      INT          NOT NULL DEFAULT 1,
        paper_size      NVARCHAR(50) NULL,
        printer_id      NVARCHAR(100) NULL,
        queue_id        NVARCHAR(100) NULL,
        submit_time     DATETIME2    NULL,
        tenant_user_id  NVARCHAR(100) NULL,
        filename        NVARCHAR(500) NULL,
        demo_session_id NVARCHAR(100) NULL,
        CONSTRAINT PK_demo_jobs PRIMARY KEY (id)
    )
    """,
    # 6) Tracking Data
    """
    IF NOT EXISTS (SELECT 1 FROM sys.tables WHERE name='tracking_data' AND schema_id=SCHEMA_ID('demo'))
    CREATE TABLE demo.tracking_data (
        id               BIGINT IDENTITY(1,1) NOT NULL,
        job_id           NVARCHAR(100) NOT NULL,
        tenant_id        NVARCHAR(100) NOT NULL,
        page_count       INT          NOT NULL DEFAULT 1,
        color            BIT          NOT NULL DEFAULT 0,
        duplex           BIT          NOT NULL DEFAULT 0,
        print_time       DATETIME2    NOT NULL,
        printer_id       NVARCHAR(100) NULL,
        print_job_status NVARCHAR(50) NOT NULL DEFAULT 'PRINT_OK',
        demo_session_id  NVARCHAR(100) NULL,
        CONSTRAINT PK_demo_tracking PRIMARY KEY (id)
    )
    """,
    # 7) Scan Jobs
    """
    IF NOT EXISTS (SELECT 1 FROM sys.tables WHERE name='jobs_scan' AND schema_id=SCHEMA_ID('demo'))
    CREATE TABLE demo.jobs_scan (
        id              NVARCHAR(100) NOT NULL,
        tenant_id       NVARCHAR(100) NOT NULL,
        printer_id      NVARCHAR(100) NULL,
        tenant_user_id  NVARCHAR(100) NULL,
        scan_time       DATETIME2    NOT NULL,
        page_count      INT          NOT NULL DEFAULT 1,
        color           BIT          NOT NULL DEFAULT 0,
        workflow_name   NVARCHAR(500) NULL,
        filename        NVARCHAR(500) NULL,
        demo_session_id NVARCHAR(100) NULL,
        CONSTRAINT PK_demo_jobs_scan PRIMARY KEY (id)
    )
    """,
    # 8) Copy Jobs
    """
    IF NOT EXISTS (SELECT 1 FROM sys.tables WHERE name='jobs_copy' AND schema_id=SCHEMA_ID('demo'))
    CREATE TABLE demo.jobs_copy (
        id              NVARCHAR(100) NOT NULL,
        tenant_id       NVARCHAR(100) NOT NULL,
        printer_id      NVARCHAR(100) NULL,
        tenant_user_id  NVARCHAR(100) NULL,
        copy_time       DATETIME2    NOT NULL,
        demo_session_id NVARCHAR(100) NULL,
        CONSTRAINT PK_demo_jobs_copy PRIMARY KEY (id)
    )
    """,
    # 9) Copy Details
    """
    IF NOT EXISTS (SELECT 1 FROM sys.tables WHERE name='jobs_copy_details' AND schema_id=SCHEMA_ID('demo'))
    CREATE TABLE demo.jobs_copy_details (
        id              NVARCHAR(100) NOT NULL,
        job_id          NVARCHAR(100) NOT NULL,
        page_count      INT          NOT NULL DEFAULT 1,
        paper_size      NVARCHAR(50) NULL,
        duplex          BIT          NOT NULL DEFAULT 0,
        color           BIT          NOT NULL DEFAULT 0,
        demo_session_id NVARCHAR(100) NULL,
        CONSTRAINT PK_demo_copy_details PRIMARY KEY (id)
    )
    """,
    # 10) Demo Sessions (Verwaltung)
    """
    IF NOT EXISTS (SELECT 1 FROM sys.tables WHERE name='demo_sessions' AND schema_id=SCHEMA_ID('demo'))
    CREATE TABLE demo.demo_sessions (
        session_id      NVARCHAR(100) NOT NULL,
        tenant_id       NVARCHAR(100) NOT NULL,
        demo_tag        NVARCHAR(100) NOT NULL,
        preset          NVARCHAR(50) NOT NULL DEFAULT 'custom',
        created_at      DATETIME2    NOT NULL,
        params_json     NVARCHAR(MAX) NULL,
        status          NVARCHAR(50) NOT NULL DEFAULT 'active',
        user_count      INT NOT NULL DEFAULT 0,
        printer_count   INT NOT NULL DEFAULT 0,
        queue_count     INT NOT NULL DEFAULT 0,
        network_count   INT NOT NULL DEFAULT 0,
        print_job_count INT NOT NULL DEFAULT 0,
        scan_job_count  INT NOT NULL DEFAULT 0,
        copy_job_count  INT NOT NULL DEFAULT 0,
        CONSTRAINT PK_demo_sessions PRIMARY KEY (session_id)
    )
    """,
    # Indexes
    """
    IF NOT EXISTS (SELECT 1 FROM sys.indexes WHERE name='IX_demo_td_tenant_time'
                   AND object_id=OBJECT_ID('demo.tracking_data'))
        CREATE INDEX IX_demo_td_tenant_time ON demo.tracking_data (tenant_id, print_time)
    """,
    """
    IF NOT EXISTS (SELECT 1 FROM sys.indexes WHERE name='IX_demo_td_session'
                   AND object_id=OBJECT_ID('demo.tracking_data'))
        CREATE INDEX IX_demo_td_session ON demo.tracking_data (demo_session_id)
    """,
    """
    IF NOT EXISTS (SELECT 1 FROM sys.indexes WHERE name='IX_demo_jobs_tenant'
                   AND object_id=OBJECT_ID('demo.jobs'))
        CREATE INDEX IX_demo_jobs_tenant ON demo.jobs (tenant_id, submit_time)
    """,
    """
    IF NOT EXISTS (SELECT 1 FROM sys.indexes WHERE name='IX_demo_users_tenant'
                   AND object_id=OBJECT_ID('demo.users'))
        CREATE INDEX IX_demo_users_tenant ON demo.users (tenant_id, email)
    """,
    """
    IF NOT EXISTS (SELECT 1 FROM sys.indexes WHERE name='IX_demo_printers_network'
                   AND object_id=OBJECT_ID('demo.printers'))
        CREATE INDEX IX_demo_printers_network ON demo.printers (tenant_id, network_id)
    """,
    """
    IF NOT EXISTS (SELECT 1 FROM sys.indexes WHERE name='IX_demo_scan_tenant'
                   AND object_id=OBJECT_ID('demo.jobs_scan'))
        CREATE INDEX IX_demo_scan_tenant ON demo.jobs_scan (tenant_id, scan_time)
    """,
    """
    IF NOT EXISTS (SELECT 1 FROM sys.indexes WHERE name='IX_demo_copy_tenant'
                   AND object_id=OBJECT_ID('demo.jobs_copy'))
        CREATE INDEX IX_demo_copy_tenant ON demo.jobs_copy (tenant_id, copy_time)
    """,
    """
    IF NOT EXISTS (SELECT 1 FROM sys.indexes WHERE name='IX_demo_queues_printer'
                   AND object_id=OBJECT_ID('demo.queues'))
        CREATE INDEX IX_demo_queues_printer ON demo.queues (tenant_id, printer_id)
    """,
    # Migration: queue_id Spalte zu jobs hinzufügen (falls alte Tabelle ohne queue_id existiert)
    """
    IF EXISTS (SELECT 1 FROM sys.tables WHERE name='jobs' AND schema_id=SCHEMA_ID('demo'))
    AND NOT EXISTS (SELECT 1 FROM sys.columns
                    WHERE object_id=OBJECT_ID('demo.jobs') AND name='queue_id')
    ALTER TABLE demo.jobs ADD queue_id NVARCHAR(100) NULL
    """,
    # Migration: preset Spalte zu demo_sessions hinzufügen
    """
    IF EXISTS (SELECT 1 FROM sys.tables WHERE name='demo_sessions' AND schema_id=SCHEMA_ID('demo'))
    AND NOT EXISTS (SELECT 1 FROM sys.columns
                    WHERE object_id=OBJECT_ID('demo.demo_sessions') AND name='preset')
    ALTER TABLE demo.demo_sessions ADD preset NVARCHAR(50) NULL
    """,
    # Migration: queue_count Spalte zu demo_sessions
    """
    IF EXISTS (SELECT 1 FROM sys.tables WHERE name='demo_sessions' AND schema_id=SCHEMA_ID('demo'))
    AND NOT EXISTS (SELECT 1 FROM sys.columns
                    WHERE object_id=OBJECT_ID('demo.demo_sessions') AND name='queue_count')
    ALTER TABLE demo.demo_sessions ADD queue_count INT NOT NULL DEFAULT 0
    """,
]


# ── Schema Setup ──────────────────────────────────────────────────────────────

def setup_schema() -> dict:
    """
    Erstellt das 'demo'-Schema und alle erforderlichen Tabellen/Indexes.
    Idempotent — bereits existierende Objekte werden nicht verändert.
    Berührt keine Printix-eigenen dbo-Tabellen.
    """
    from .sql_client import execute_script
    errors = []
    created = []
    for stmt in SCHEMA_STATEMENTS:
        label = stmt.strip().split("\n")[0].strip()[:80]
        try:
            execute_script([stmt])
            created.append(label)
        except Exception as e:
            errors.append({"statement": label, "error": str(e)})

    return {
        "success":  len(errors) == 0,
        "executed": len(created),
        "errors":   errors,
        "message":  "Schema 'demo' bereit — alle Tabellen angelegt." if not errors
                    else f"{len(errors)} Fehler beim Setup.",
        "note":     "Printix dbo-Tabellen wurden nicht verändert.",
    }


# ── Hilfsfunktionen ───────────────────────────────────────────────────────────

def _uid() -> str:
    return str(uuid.uuid4())


def _pick_name(languages: list[str], rng: random.Random) -> tuple[str, str, str]:
    lang = rng.choice(languages)
    if lang not in NAMES:
        lang = "de"
    bank = NAMES[lang]
    return rng.choice(bank["first"]), rng.choice(bank["last"]), lang


def _email(first: str, last: str, domain: str) -> str:
    def _ascii(s: str) -> str:
        # Lowercase first so we can handle both cases with a single replacement map
        s = s.lower()
        replacements = {
            "ä": "ae", "ö": "oe", "ü": "ue", "ß": "ss", "á": "a", "à": "a", "â": "a",
            "é": "e", "è": "e", "ê": "e", "ë": "e", "í": "i", "ì": "i", "î": "i", "ï": "i",
            "ó": "o", "ò": "o", "ô": "o", "ú": "u", "ù": "u", "û": "u", "ñ": "n", "ç": "c",
            "ø": "o", "å": "a", "æ": "ae",
            "ł": "l", "ń": "n", "ź": "z", "ż": "z", "ś": "s", "ć": "c", "ą": "a", "ę": "e",
            "ã": "a", "õ": "o", "ô": "o", "ğ": "g", "ş": "s", "ı": "i", "ð": "d", "þ": "th",
        }
        for k, v in replacements.items():
            s = s.replace(k, v)
        return "".join(c for c in s if c.isalnum() or c == ".")
    f = _ascii(first)
    l = _ascii(last.replace(" ", "-"))
    return f"{f}.{l}@{domain}"


def _working_days(start: datetime, end: datetime) -> list[datetime]:
    days, cur = [], start
    while cur <= end:
        if cur.weekday() < 5:
            days.append(cur)
        cur += timedelta(days=1)
    return days


def _random_time(day: datetime, rng: random.Random) -> datetime:
    """Realistisches Bürostunden-Zeitprofil."""
    segments = [
        (570, 660, 35),   # 9:30–11:00 (Morgenpeak)
        (780, 900, 30),   # 13:00–15:00 (Nachmittagspeak)
        (450, 570, 10),   # 7:30–9:30 (Früh)
        (660, 780, 10),   # 11:00–13:00 (Mittag)
        (900, 1110, 15),  # 15:00–18:30 (Spät)
    ]
    total = sum(w for _, _, w in segments)
    pick = rng.randint(1, total)
    cumul = 0
    for s_min, e_min, w in segments:
        cumul += w
        if pick <= cumul:
            minute = rng.randint(s_min, e_min - 1)
            break
    else:
        minute = 540
    return day.replace(hour=minute // 60, minute=minute % 60,
                       second=rng.randint(0, 59), microsecond=0)


def _page_count(rng: random.Random, dept: str = "") -> int:
    """Log-Normalverteilung für Seitenanzahl, leicht erhöht für druckintensive Abteilungen."""
    base = 1.1 if dept in ("FIN", "VTR", "PRD", "LOG") else 1.0
    pages = int(math.exp(rng.gauss(base, 0.85)))
    return max(1, min(200, pages))


def _filename_print(rng: random.Random, ts: datetime) -> str:
    tpl = rng.choice(_PRINT_TEMPLATES)
    return tpl.format(
        nr=rng.randint(1, 9999), date=ts.strftime("%Y-%m-%d"),
        year=ts.year, q=((ts.month - 1) // 3) + 1,
        kw=ts.isocalendar()[1], maj=rng.randint(1, 5), min=rng.randint(0, 9),
    )


def _filename_scan(rng: random.Random, ts: datetime) -> str:
    tpl = rng.choice(_SCAN_TEMPLATES)
    return tpl.format(
        nr=rng.randint(1, 9999), date=ts.strftime("%Y%m%d"),
        time=ts.strftime("%H%M%S"),
    )


# ── Daten-Generierung ─────────────────────────────────────────────────────────

def _gen_users(tenant_id, user_count, languages, session_id, rng, email_domain):
    users, seen = [], set()
    attempts = 0
    while len(users) < user_count and attempts < user_count * 15:
        attempts += 1
        first, last, _ = _pick_name(languages, rng)
        email = _email(first, last, email_domain)
        if email in seen:
            email = f"{email.split('@')[0]}{rng.randint(2, 99)}@{email_domain}"
        seen.add(email)
        dept = rng.choice(DEPARTMENTS)
        users.append({
            "id": _uid(), "tenant_id": tenant_id,
            "email": email, "name": f"{first} {last}",
            "department": dept,
            "demo_session_id": session_id,
        })
    logger.info("Demo: %d Benutzer generiert (versuche: %d)", len(users), attempts)
    return users


def _gen_networks(tenant_id, sites, session_id):
    return [{"id": _uid(), "tenant_id": tenant_id, "name": s, "demo_session_id": session_id}
            for s in sites]


def _gen_printers(tenant_id, printer_count, networks, session_id, rng):
    printers, used = [], set()
    models = rng.choices(PRINTER_MODELS, k=printer_count)
    for i, (vendor, model, prefix, _) in enumerate(models):
        net   = networks[i % len(networks)]
        floor = rng.choice(FLOOR_CODES)
        name  = f"[DEMO] {prefix}-{floor}-{i+1:02d}"
        if name in used:
            name += f"-{rng.randint(10, 99)}"
        used.add(name)
        printers.append({
            "id": _uid(), "tenant_id": tenant_id,
            "name": name, "model_name": model, "vendor_name": vendor,
            "network_id": net["id"], "location": f"{net['name']} / {floor}",
            "demo_session_id": session_id,
        })
    return printers


def _gen_queues(tenant_id, printers, queue_count_per_printer, session_id, rng):
    """Generiert Print-Queues pro Drucker."""
    queues = []
    available_suffixes = QUEUE_SUFFIXES[:max(1, queue_count_per_printer)]
    selected = rng.sample(available_suffixes, min(queue_count_per_printer, len(available_suffixes)))
    for printer in printers:
        for suffix, qtype in selected:
            queues.append({
                "id": _uid(), "tenant_id": tenant_id,
                "name": f"{printer['name']}{suffix}",
                "queue_type": qtype,
                "printer_id": printer["id"],
                "demo_session_id": session_id,
            })
    return queues


def _gen_print_jobs(tenant_id, users, printers, queues, working_days,
                    jobs_per_user_day, session_id, rng,
                    color_ratio=0.30, duplex_ratio=0.60):
    """
    Generiert Druckjobs mit realistischer Volumenverteilung.
    - Abteilungsbasierte Gewichtung
    - Monatliche Saisonalität
    - Zufällige Benutzeraktivität
    """
    jobs_rows, tracking_rows = [], []
    # Gewichtung pro Benutzer (Abteilung × zufälliger Faktor)
    user_weights = []
    for u in users:
        dept_w = DEPT_PRINT_WEIGHT.get(u.get("department", "IT"), 1.0)
        personal_w = rng.uniform(0.3, 2.5)
        user_weights.append(dept_w * personal_w)

    # Queues nach Drucker gruppieren für schnellen Lookup
    queues_by_printer: dict[str, list] = {}
    for q in queues:
        queues_by_printer.setdefault(q["printer_id"], []).append(q)

    for day in working_days:
        mf = MONTH_FACTORS.get(day.month, 1.0)
        # Quartalsend-Boost (letzter Monat eines Quartals = mehr Druck)
        if day.month in (3, 6, 9, 12) and day.day >= 20:
            mf *= 1.20
        for user, weight in zip(users, user_weights):
            n = max(0, int(rng.gauss(jobs_per_user_day * weight * mf, 1.0)))
            dept = user.get("department", "IT")
            for _ in range(n):
                ts      = _random_time(day, rng)
                pages   = _page_count(rng, dept)
                color   = 1 if rng.random() < color_ratio else 0
                duplex  = 1 if rng.random() < duplex_ratio else 0
                paper   = rng.choice(PAPER_SIZES)
                printer = rng.choice(printers)
                # Queue zu diesem Drucker wählen
                pqs = queues_by_printer.get(printer["id"], [])
                queue_id = rng.choice(pqs)["id"] if pqs else None
                job_id   = _uid()
                jobs_rows.append((job_id, tenant_id, color, duplex, pages, paper,
                                   printer["id"], queue_id, ts, user["id"],
                                   _filename_print(rng, ts), session_id))
                tracking_rows.append((job_id, tenant_id, pages, color, duplex, ts,
                                      printer["id"], "PRINT_OK", session_id))
    return jobs_rows, tracking_rows


def _gen_scan_jobs(tenant_id, users, printers, working_days, session_id, rng, scan_prob=0.33):
    rows = []
    for day in working_days:
        mf = MONTH_FACTORS.get(day.month, 1.0)
        for user in users:
            if rng.random() > (scan_prob * mf):
                continue
            ts = _random_time(day, rng)
            rows.append((_uid(), tenant_id, rng.choice(printers)["id"], user["id"],
                         ts, rng.randint(1, 20), 1 if rng.random() < 0.15 else 0,
                         rng.choice(CAPTURE_WORKFLOWS), _filename_scan(rng, ts), session_id))
    return rows


def _gen_copy_jobs(tenant_id, users, printers, working_days, session_id, rng, copy_prob=0.25):
    copy_rows, detail_rows = [], []
    for day in working_days:
        mf = MONTH_FACTORS.get(day.month, 1.0)
        for user in users:
            if rng.random() > (copy_prob * mf):
                continue
            ts     = _random_time(day, rng)
            job_id = _uid()
            copy_rows.append((job_id, tenant_id, rng.choice(printers)["id"],
                              user["id"], ts, session_id))
            detail_rows.append((_uid(), job_id, rng.randint(1, 30),
                                rng.choice(PAPER_SIZES),
                                1 if rng.random() < 0.50 else 0,
                                1 if rng.random() < 0.20 else 0,
                                session_id))
    return copy_rows, detail_rows


def _bulk(sql, rows, batch=300):
    """Sicheres Bulk-Insert mit kleinen Batches um Timeouts zu vermeiden."""
    from .sql_client import execute_many
    total = 0
    for i in range(0, len(rows), batch):
        chunk = rows[i:i + batch]
        total += execute_many(sql, chunk)
        logger.debug("Bulk-Insert: %d/%d Zeilen eingefügt", total, len(rows))
    return total


# ── Öffentliche API ───────────────────────────────────────────────────────────

def generate_demo_dataset(
    tenant_id: str,
    preset: str = "custom",
    user_count: int = 15,
    printer_count: int = 6,
    queue_count: int = 2,
    months: int = 12,
    languages: Optional[list[str]] = None,
    sites: Optional[list[str]] = None,
    demo_tag: str = "",
    jobs_per_user_day: float = 3.0,
    color_ratio: float = 0.30,
    duplex_ratio: float = 0.60,
    seed: Optional[int] = None,
) -> dict:
    """
    Generiert ein vollständiges Demo-Dataset und schreibt es in demo.* Tabellen.
    Printix dbo-Tabellen werden nicht berührt.

    Bei Preset != 'custom' werden die Preset-Werte als Standard verwendet,
    können aber durch explizite Parameter überschrieben werden.
    """
    from .sql_client import execute_write

    # Preset-Werte als Standardwerte laden
    if preset in COMPANY_PRESETS and preset != "custom":
        p = COMPANY_PRESETS[preset]
        user_count       = user_count       if user_count != 15       else p["user_count"]
        printer_count    = printer_count    if printer_count != 6     else p["printer_count"]
        queue_count      = queue_count      if queue_count != 2       else p["queue_count"]
        months           = months           if months != 12            else p["months"]
        jobs_per_user_day = jobs_per_user_day if jobs_per_user_day != 3.0 else p["jobs_per_day"]
        color_ratio      = p.get("color_ratio",  color_ratio)
        duplex_ratio     = p.get("duplex_ratio", duplex_ratio)
        if languages is None:
            languages = p.get("languages", ["de", "en"])
        if sites is None:
            sites = p.get("sites", ["Hauptsitz"])

    # Limits
    user_count    = max(1,   min(500, user_count))
    printer_count = max(1,   min(100, printer_count))
    queue_count   = max(1,   min(5,   queue_count))
    months        = max(1,   min(36,  months))
    languages     = [l for l in (languages or ["de"]) if l in NAMES] or ["de"]
    sites         = sites or ["Hauptsitz", "Niederlassung"]
    demo_tag      = demo_tag.strip() or f"DEMO_{datetime.now().strftime('%Y%m%d_%H%M%S')}"
    email_domain  = f"demo-{demo_tag.lower().replace(' ', '').replace('_', '')[:20]}.invalid"

    rng        = random.Random(seed)
    session_id = f"{demo_tag}_{_uid()[:8]}"
    now        = datetime.now()
    end_dt     = now.replace(hour=23, minute=59, second=59, microsecond=0)
    start_dt   = (now - timedelta(days=months * 30)).replace(
        hour=0, minute=0, second=0, microsecond=0)

    logger.info("Demo-Generator START: preset=%s session=%s tenant=%s "
                "user=%d printer=%d queue=%d months=%d",
                preset, session_id, tenant_id,
                user_count, printer_count, queue_count, months)

    users    = _gen_users(tenant_id, user_count, languages, session_id, rng, email_domain)
    networks = _gen_networks(tenant_id, sites, session_id)
    printers = _gen_printers(tenant_id, printer_count, networks, session_id, rng)
    queues   = _gen_queues(tenant_id, printers, queue_count, session_id, rng)
    wdays    = _working_days(start_dt, end_dt)

    logger.info("Demo: %d Arbeitstage im Zeitraum %s – %s",
                len(wdays), start_dt.date(), end_dt.date())

    jobs_rows, tracking_rows = _gen_print_jobs(
        tenant_id, users, printers, queues, wdays,
        jobs_per_user_day, session_id, rng, color_ratio, duplex_ratio)
    scan_rows = _gen_scan_jobs(
        tenant_id, users, printers, wdays, session_id, rng,
        COMPANY_PRESETS.get(preset, {}).get("scan_prob", 0.33))
    copy_rows, copy_detail_rows = _gen_copy_jobs(
        tenant_id, users, printers, wdays, session_id, rng,
        COMPANY_PRESETS.get(preset, {}).get("copy_prob", 0.25))

    logger.info("Datenmenge: %d Druckjobs | %d Scans | %d Kopien | %d Queues",
                len(jobs_rows), len(scan_rows), len(copy_rows), len(queues))

    # ── Daten schreiben ────────────────────────────────────────────────────────
    _bulk("INSERT INTO demo.networks (id,tenant_id,name,demo_session_id) VALUES (?,?,?,?)",
          [(n["id"], n["tenant_id"], n["name"], n["demo_session_id"]) for n in networks])

    _bulk("INSERT INTO demo.users (id,tenant_id,email,name,department,demo_session_id) "
          "VALUES (?,?,?,?,?,?)",
          [(u["id"], u["tenant_id"], u["email"], u["name"],
            u["department"], u["demo_session_id"]) for u in users])

    _bulk("INSERT INTO demo.printers "
          "(id,tenant_id,name,model_name,vendor_name,network_id,location,demo_session_id) "
          "VALUES (?,?,?,?,?,?,?,?)",
          [(p["id"], p["tenant_id"], p["name"], p["model_name"], p["vendor_name"],
            p["network_id"], p["location"], p["demo_session_id"]) for p in printers])

    _bulk("INSERT INTO demo.queues (id,tenant_id,name,queue_type,printer_id,demo_session_id) "
          "VALUES (?,?,?,?,?,?)",
          [(q["id"], q["tenant_id"], q["name"], q["queue_type"],
            q["printer_id"], q["demo_session_id"]) for q in queues])

    _bulk("INSERT INTO demo.jobs "
          "(id,tenant_id,color,duplex,page_count,paper_size,printer_id,queue_id,"
          "submit_time,tenant_user_id,filename,demo_session_id) "
          "VALUES (?,?,?,?,?,?,?,?,?,?,?,?)",
          jobs_rows)

    _bulk("INSERT INTO demo.tracking_data "
          "(job_id,tenant_id,page_count,color,duplex,print_time,printer_id,"
          "print_job_status,demo_session_id) VALUES (?,?,?,?,?,?,?,?,?)",
          tracking_rows)

    if scan_rows:
        _bulk("INSERT INTO demo.jobs_scan "
              "(id,tenant_id,printer_id,tenant_user_id,scan_time,page_count,color,"
              "workflow_name,filename,demo_session_id) VALUES (?,?,?,?,?,?,?,?,?,?)",
              scan_rows)

    if copy_rows:
        _bulk("INSERT INTO demo.jobs_copy "
              "(id,tenant_id,printer_id,tenant_user_id,copy_time,demo_session_id) "
              "VALUES (?,?,?,?,?,?)",
              copy_rows)
        _bulk("INSERT INTO demo.jobs_copy_details "
              "(id,job_id,page_count,paper_size,duplex,color,demo_session_id) "
              "VALUES (?,?,?,?,?,?,?)",
              copy_detail_rows)

    params_json = json.dumps({
        "preset": preset, "user_count": user_count, "printer_count": printer_count,
        "queue_count": queue_count, "months": months,
        "languages": languages, "sites": sites,
        "jobs_per_user_day": jobs_per_user_day,
        "color_ratio": color_ratio, "duplex_ratio": duplex_ratio,
        "seed": seed, "start": start_dt.isoformat(), "end": end_dt.isoformat(),
    })
    execute_write(
        "INSERT INTO demo.demo_sessions "
        "(session_id,tenant_id,demo_tag,preset,created_at,params_json,status,"
        "user_count,printer_count,queue_count,network_count,"
        "print_job_count,scan_job_count,copy_job_count) "
        "VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?)",
        (session_id, tenant_id, demo_tag, preset, now, params_json, "active",
         len(users), len(printers), len(queues), len(networks),
         len(jobs_rows), len(scan_rows), len(copy_rows)),
    )

    logger.info("Demo-Datensatz fertig: session=%s | %d Jobs | %d Scans | %d Kopien",
                session_id, len(jobs_rows), len(scan_rows), len(copy_rows))
    return {
        "session_id":   session_id,
        "demo_tag":     demo_tag,
        "preset":       preset,
        "period":       f"{start_dt.date()} – {end_dt.date()}",
        "working_days": len(wdays),
        "users":        len(users),
        "printers":     len(printers),
        "queues":       len(queues),
        "networks":     len(networks),
        "print_jobs":   len(jobs_rows),
        "scan_jobs":    len(scan_rows),
        "copy_jobs":    len(copy_rows),
        "schema":       "demo (kein Konflikt mit Printix dbo-Tabellen)",
        "status":       "ok",
        "rollback_cmd": f'printix_demo_rollback(demo_tag="{demo_tag}")',
    }


def rollback_demo(tenant_id: str, demo_tag: str) -> dict:
    """Löscht alle Demo-Daten einer bestimmten Session aus dem demo-Schema."""
    from .sql_client import execute_write, query_fetchall

    sessions = query_fetchall(
        "SELECT session_id FROM demo.demo_sessions WHERE tenant_id=? AND demo_tag=?",
        (tenant_id, demo_tag),
    )
    session_ids = [s["session_id"] for s in sessions]
    if not session_ids:
        return {"deleted": {}, "sessions_found": 0,
                "message": f"Keine Sessions für Tag '{demo_tag}' gefunden."}

    deleted: dict[str, int] = {}
    tables = [
        "demo.jobs_copy_details", "demo.jobs_copy", "demo.jobs_scan",
        "demo.tracking_data", "demo.jobs", "demo.queues", "demo.printers",
        "demo.users", "demo.networks", "demo.demo_sessions",
    ]
    for sid in session_ids:
        for tbl in tables:
            col = "session_id" if tbl == "demo.demo_sessions" else "demo_session_id"
            try:
                n = execute_write(f"DELETE FROM {tbl} WHERE {col}=?", (sid,))
                deleted[tbl] = deleted.get(tbl, 0) + n
            except Exception as e:
                logger.warning("Rollback-Fehler %s: %s", tbl, e)

    return {
        "deleted":        deleted,
        "sessions_found": len(session_ids),
        "total_deleted":  sum(deleted.values()),
        "demo_tag":       demo_tag,
        "status":         "ok",
    }


def get_demo_status(tenant_id: str) -> dict:
    """Gibt eine Übersicht aller Demo-Sessions für den Tenant zurück."""
    from .sql_client import query_fetchall
    try:
        sessions = query_fetchall(
            "SELECT session_id, demo_tag, "
            "ISNULL(preset,'custom') AS preset, "
            "created_at, status, "
            "user_count, printer_count, "
            "ISNULL(queue_count,0) AS queue_count, "
            "network_count, "
            "print_job_count, scan_job_count, copy_job_count "
            "FROM demo.demo_sessions WHERE tenant_id=? ORDER BY created_at DESC",
            (tenant_id,),
        )
    except Exception as e:
        return {"error": f"Tabelle demo.demo_sessions nicht gefunden — bitte zuerst "
                         f"printix_demo_setup_schema ausführen. ({e})"}

    return {
        "sessions":         sessions,
        "session_count":    len(sessions),
        "total_print_jobs": sum((s.get("print_job_count") or 0) for s in sessions),
        "total_demo_rows":  sum(
            (s.get("print_job_count") or 0) + (s.get("scan_job_count") or 0) +
            (s.get("copy_job_count") or 0) for s in sessions),
        "hint": "Rollback: printix_demo_rollback(demo_tag='TAG')",
    }
